{% doc %}
  @prompt
    🟠 5. Why Choose Petaloons (TRUST SECTION)
    
    Icons + short text:
    
    🧵 Premium Fabric
    🐶 Perfect Fit for All Breeds
    🚚 Fast Delivery Across India
    💰 Affordable Pricing
    ❤️ Made for Comfort
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-trust-section__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-trust-section__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
  }

  .ai-trust-section__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-trust-section__item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ block.settings.item_alignment }};
    text-align: {{ block.settings.item_alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
  }

  .ai-trust-section__icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    line-height: 1;
  }

  .ai-trust-section__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    font-weight: {{ block.settings.text_weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-trust-section__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-trust-section__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-trust-section__icon-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.icon_size }}px * 0.85);
    }

    .ai-trust-section__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }
  }
{% endstyle %}

<trust-section-{{ ai_gen_id }} class="ai-trust-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-section__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-trust-section__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-trust-section__grid-{{ ai_gen_id }}">
      {% if block.settings.show_item_1 %}
        <div class="ai-trust-section__item-{{ ai_gen_id }}">
          <div class="ai-trust-section__icon-{{ ai_gen_id }}">{{ block.settings.icon_1 }}</div>
          <p class="ai-trust-section__text-{{ ai_gen_id }}">{{ block.settings.text_1 }}</p>
        </div>
      {% endif %}

      {% if block.settings.show_item_2 %}
        <div class="ai-trust-section__item-{{ ai_gen_id }}">
          <div class="ai-trust-section__icon-{{ ai_gen_id }}">{{ block.settings.icon_2 }}</div>
          <p class="ai-trust-section__text-{{ ai_gen_id }}">{{ block.settings.text_2 }}</p>
        </div>
      {% endif %}

      {% if block.settings.show_item_3 %}
        <div class="ai-trust-section__item-{{ ai_gen_id }}">
          <div class="ai-trust-section__icon-{{ ai_gen_id }}">{{ block.settings.icon_3 }}</div>
          <p class="ai-trust-section__text-{{ ai_gen_id }}">{{ block.settings.text_3 }}</p>
        </div>
      {% endif %}

      {% if block.settings.show_item_4 %}
        <div class="ai-trust-section__item-{{ ai_gen_id }}">
          <div class="ai-trust-section__icon-{{ ai_gen_id }}">{{ block.settings.icon_4 }}</div>
          <p class="ai-trust-section__text-{{ ai_gen_id }}">{{ block.settings.text_4 }}</p>
        </div>
      {% endif %}

      {% if block.settings.show_item_5 %}
        <div class="ai-trust-section__item-{{ ai_gen_id }}">
          <div class="ai-trust-section__icon-{{ ai_gen_id }}">{{ block.settings.icon_5 }}</div>
          <p class="ai-trust-section__text-{{ ai_gen_id }}">{{ block.settings.text_5 }}</p>
        </div>
      {% endif %}
    </div>
  </div>
</trust-section-{{ ai_gen_id }}>

