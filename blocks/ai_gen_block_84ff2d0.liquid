{% doc %}
  @prompt
    🔥 ADD THIS (HIGH IMPACT)
    
    Right below hero:
    
    🟢 Doctors Available Now  
    ⚠️ Limited Slots Today  
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-status-banner-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-status-banner__container-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    flex-wrap: wrap;
  }

  .ai-status-banner__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-status-banner__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-status-banner__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-status-banner__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-status-banner__divider-{{ ai_gen_id }} {
    width: 1px;
    height: {{ block.settings.divider_height }}px;
    background-color: {{ block.settings.divider_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-status-banner__container-{{ ai_gen_id }} {
      gap: {{ block.settings.gap | times: 0.7 }}px;
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
    }

    .ai-status-banner__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-status-banner__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-status-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-status-banner__container-{{ ai_gen_id }}">
    {% if block.settings.show_available %}
      <div class="ai-status-banner__item-{{ ai_gen_id }}">
        <div class="ai-status-banner__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.available_icon_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <p class="ai-status-banner__text-{{ ai_gen_id }}">{{ block.settings.available_text }}</p>
      </div>

      {% if block.settings.show_divider and block.settings.show_limited %}
        <div class="ai-status-banner__divider-{{ ai_gen_id }}"></div>
      {% endif %}
    {% endif %}

    {% if block.settings.show_limited %}
      <div class="ai-status-banner__item-{{ ai_gen_id }}">
        <div class="ai-status-banner__icon-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.limited_icon_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
            <line x1="12" y1="9" x2="12" y2="13"></line>
            <line x1="12" y1="17" x2="12.01" y2="17"></line>
          </svg>
        </div>
        <p class="ai-status-banner__text-{{ ai_gen_id }}">{{ block.settings.limited_text }}</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Status banner",
  "settings": [
    {
      "type": "header",
      "content": "Available status"
    },
    {
      "type": "checkbox",
      "id": "show_available",
      "label": "Show available status",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "available_text",
      "label": "Available text",
      "default": "Doctors Available Now"
    },
    {
      "type": "color",
      "id": "available_icon_color",
      "label": "Icon color",
      "default": "#22c55e"
    },
    {
      "type": "header",
      "content": "Limited status"
    },
    {
      "type": "checkbox",
      "id": "show_limited",
      "label": "Show limited status",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "limited_text",
      "label": "Limited text",
      "default": "Limited Slots Today"
    },
    {
      "type": "color",
      "id": "limited_icon_color",
      "label": "Icon color",
      "default": "#f59e0b"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#fef3c7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 12,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between items",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Divider"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show divider",
      "default": true
    },
    {
      "type": "range",
      "id": "divider_height",
      "label": "Divider height",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#d1d5db"
    }
  ],
  "presets": [
    {
      "name": "Status banner"
    }
  ]
}
{% endschema %}
