{% doc %}
  @prompt
    Generate the below in blocks 
    ⭐ 4.8 Rating  
    👨‍⚕️ 10+ Years Experience  
    🐾 500+ Pets Treated  
    📄 Digital Prescription Provided  
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stats-container-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-stats-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-stat-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
    {% if block.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif block.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  .ai-stat-icon-{{ ai_gen_id }} {
    font-size: {{ block.settings.icon_size }}px;
    line-height: 1;
    flex-shrink: 0;
  }

  .ai-stat-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    margin: 0;
    line-height: 1.3;
  }

  @media screen and (max-width: 749px) {
    .ai-stats-wrapper-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<ai-stats-{{ ai_gen_id }} class="ai-stats-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-stats-wrapper-{{ ai_gen_id }}">
    {% if block.settings.stat_1_enabled %}
      <div class="ai-stat-item-{{ ai_gen_id }}">
        <span class="ai-stat-icon-{{ ai_gen_id }}">{{ block.settings.stat_1_icon }}</span>
        <p class="ai-stat-text-{{ ai_gen_id }}">{{ block.settings.stat_1_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.stat_2_enabled %}
      <div class="ai-stat-item-{{ ai_gen_id }}">
        <span class="ai-stat-icon-{{ ai_gen_id }}">{{ block.settings.stat_2_icon }}</span>
        <p class="ai-stat-text-{{ ai_gen_id }}">{{ block.settings.stat_2_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.stat_3_enabled %}
      <div class="ai-stat-item-{{ ai_gen_id }}">
        <span class="ai-stat-icon-{{ ai_gen_id }}">{{ block.settings.stat_3_icon }}</span>
        <p class="ai-stat-text-{{ ai_gen_id }}">{{ block.settings.stat_3_text }}</p>
      </div>
    {% endif %}

    {% if block.settings.stat_4_enabled %}
      <div class="ai-stat-item-{{ ai_gen_id }}">
        <span class="ai-stat-icon-{{ ai_gen_id }}">{{ block.settings.stat_4_icon }}</span>
        <p class="ai-stat-text-{{ ai_gen_id }}">{{ block.settings.stat_4_text }}</p>
      </div>
    {% endif %}
  </div>
</ai-stats-{{ ai_gen_id }}>

<script>
  (function() {
    class AiStats{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('ai-stats-{{ ai_gen_id }}', AiStats{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
