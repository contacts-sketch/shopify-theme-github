{% doc %}
  @prompt
    Generate 2,00,000+
    
    Happy Users
    
    20,000+
    
    Verified Doctors
    
    25+
    
    Specialities
    
    4.5 / 5
    
    App Rating
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stats-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-stats-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.gap }}px;
    max-width: 100%;
  }

  .ai-stat-item-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
  }

  .ai-stat-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: {{ block.settings.number_weight }};
    color: {{ block.settings.number_color }};
    line-height: 1.2;
    margin: 0 0 {{ block.settings.number_spacing }}px 0;
  }

  .ai-stat-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
    color: {{ block.settings.label_color }};
    line-height: 1.4;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-stats-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-stat-number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.8);
    }

    .ai-stat-label-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.label_size }}px * 0.9);
    }
  }
{% endstyle %}

<stats-block-{{ ai_gen_id }} class="ai-stats-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-stats-container-{{ ai_gen_id }}">
    {% if block.settings.stat_1_number != blank %}
      <div class="ai-stat-item-{{ ai_gen_id }}">
        <div class="ai-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_1_number }}</div>
        <div class="ai-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_1_label }}</div>
      </div>
    {% endif %}

    {% if block.settings.stat_2_number != blank %}
      <div class="ai-stat-item-{{ ai_gen_id }}">
        <div class="ai-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_2_number }}</div>
        <div class="ai-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_2_label }}</div>
      </div>
    {% endif %}

    {% if block.settings.stat_3_number != blank %}
      <div class="ai-stat-item-{{ ai_gen_id }}">
        <div class="ai-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_3_number }}</div>
        <div class="ai-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_3_label }}</div>
      </div>
    {% endif %}

    {% if block.settings.stat_4_number != blank %}
      <div class="ai-stat-item-{{ ai_gen_id }}">
        <div class="ai-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_4_number }}</div>
        <div class="ai-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_4_label }}</div>
      </div>
    {% endif %}
  </div>
</stats-block-{{ ai_gen_id }}>

<script>
  (function() {
    class StatsBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('stats-block-{{ ai_gen_id }}', StatsBlock{{ ai_gen_id }});
  })();
</script>

