{% doc %}
  @prompt
    Need better way to show
    
    Quality care at reasonable pricing.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-value-prop-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-value-prop-container-{{ ai_gen_id }} {
    background: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: {{ block.settings.padding }}px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .ai-value-prop-badge-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 20px;
    border-radius: 50px;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .ai-value-prop-badge-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
  }

  .ai-value-prop-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-weight: 700;
    line-height: 1.2;
  }

  .ai-value-prop-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_size }}px;
    color: {{ block.settings.subheading_color }};
    margin: 0 0 32px;
    line-height: 1.5;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-value-prop-features-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 24px;
    margin-top: 32px;
  }

  .ai-value-prop-feature-{{ ai_gen_id }} {
    background: {{ block.settings.feature_bg_color }};
    padding: 24px;
    border-radius: {{ block.settings.feature_border_radius }}px;
    text-align: center;
  }

  .ai-value-prop-feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto 16px;
    color: {{ block.settings.icon_color }};
  }

  .ai-value-prop-feature-title-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.feature_title_color }};
    margin: 0 0 8px;
  }

  .ai-value-prop-feature-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.feature_text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-value-prop-cta-{{ ai_gen_id }} {
    margin-top: 32px;
  }

  .ai-value-prop-button-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    padding: 16px 40px;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    transition: all 0.3s ease;
  }

  .ai-value-prop-button-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-value-prop-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-value-prop-subheading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subheading_size }}px * 0.9);
    }

    .ai-value-prop-features-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }
  }
{% endstyle %}

<value-proposition-{{ ai_gen_id }} class="ai-value-prop-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-value-prop-container-{{ ai_gen_id }}">
    {% if block.settings.show_badge %}
      <div class="ai-value-prop-badge-{{ ai_gen_id }}">
        <svg class="ai-value-prop-badge-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
        {{ block.settings.badge_text }}
      </div>
    {% endif %}

    <h2 class="ai-value-prop-heading-{{ ai_gen_id }}">
      {{ block.settings.heading }}
    </h2>

    {% if block.settings.subheading != blank %}
      <p class="ai-value-prop-subheading-{{ ai_gen_id }}">
        {{ block.settings.subheading }}
      </p>
    {% endif %}

    <div class="ai-value-prop-features-{{ ai_gen_id }}">
      {% if block.settings.show_feature_1 %}
        <div class="ai-value-prop-feature-{{ ai_gen_id }}">
          <svg class="ai-value-prop-feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          <h3 class="ai-value-prop-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_1_title }}</h3>
          <p class="ai-value-prop-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_1_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.show_feature_2 %}
        <div class="ai-value-prop-feature-{{ ai_gen_id }}">
          <svg class="ai-value-prop-feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="1" x2="12" y2="23"/>
            <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
          <h3 class="ai-value-prop-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_2_title }}</h3>
          <p class="ai-value-prop-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_2_text }}</p>
        </div>
      {% endif %}

      {% if block.settings.show_feature_3 %}
        <div class="ai-value-prop-feature-{{ ai_gen_id }}">
          <svg class="ai-value-prop-feature-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
          <h3 class="ai-value-prop-feature-title-{{ ai_gen_id }}">{{ block.settings.feature_3_title }}</h3>
          <p class="ai-value-prop-feature-text-{{ ai_gen_id }}">{{ block.settings.feature_3_text }}</p>
        </div>
      {% endif %}
    </div>

    {% if block.settings.show_cta and block.settings.button_text != blank %}
      <div class="ai-value-prop-cta-{{ ai_gen_id }}">
        <a href="{{ block.settings.button_link }}" class="ai-value-prop-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      </div>
    {% endif %}
  </div>
</value-proposition-{{ ai_gen_id }}>

<script>
  (function() {
    class ValueProposition{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('value-proposition-{{ ai_gen_id }}', ValueProposition{{ ai_gen_id }});
  })();
</script>

