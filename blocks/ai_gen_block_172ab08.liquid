{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-consultation-specialties-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-consultation-specialties__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-consultation-specialties__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-consultation-specialties__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.subtitle_spacing }}px;
    font-weight: 600;
  }

  .ai-consultation-specialties__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 {{ block.settings.view_all_spacing }}px;
    line-height: 1.5;
  }

  .ai-consultation-specialties__view-all-{{ ai_gen_id }} {
    display: inline-block;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    font-size: {{ block.settings.link_size }}px;
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .ai-consultation-specialties__view-all-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-consultation-specialties__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-consultation-specialties__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-consultation-specialties__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  .ai-consultation-specialties__card-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    margin: 0 auto {{ block.settings.image_spacing }}px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-consultation-specialties__card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-consultation-specialties__card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-consultation-specialties__card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-consultation-specialties__card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 {{ block.settings.button_spacing }}px;
    font-weight: 500;
    line-height: 1.4;
  }

  .ai-consultation-specialties__card-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: background-color 0.3s ease, transform 0.2s ease;
    border: none;
    cursor: pointer;
  }

  .ai-consultation-specialties__card-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: scale(1.05);
  }

  @media screen and (max-width: 989px) {
    .ai-consultation-specialties__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
    }

    .ai-consultation-specialties__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.85);
    }

    .ai-consultation-specialties__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-consultation-specialties__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }

    .ai-consultation-specialties__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.75);
    }

    .ai-consultation-specialties__subtitle-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtitle_size }}px * 0.85);
    }

    .ai-consultation-specialties__card-image-wrapper-{{ ai_gen_id }} {
      width: calc({{ block.settings.image_size }}px * 0.8);
      height: calc({{ block.settings.image_size }}px * 0.8);
    }
  }
{% endstyle %}

<consultation-specialties-{{ ai_gen_id }}
  class="ai-consultation-specialties-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-consultation-specialties__container-{{ ai_gen_id }}">
    <div class="ai-consultation-specialties__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-consultation-specialties__title-{{ ai_gen_id }}">
          {{ block.settings.title }}
        </h2>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <p class="ai-consultation-specialties__subtitle-{{ ai_gen_id }}">
          {{ block.settings.subtitle }}
        </p>
      {% endif %}

      {% if block.settings.view_all_text != blank and block.settings.view_all_link != blank %}
        <a
          href="{{ block.settings.view_all_link }}"
          class="ai-consultation-specialties__view-all-{{ ai_gen_id }}"
        >
          {{ block.settings.view_all_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-consultation-specialties__grid-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign card_enabled_key = 'card_' | append: i | append: '_enabled'
          assign card_image_key = 'card_' | append: i | append: '_image'
          assign card_title_key = 'card_' | append: i | append: '_title'
          assign card_button_text_key = 'card_' | append: i | append: '_button_text'
          assign card_button_link_key = 'card_' | append: i | append: '_button_link'

          assign card_enabled = block.settings[card_enabled_key]
          assign card_image = block.settings[card_image_key]
          assign card_title = block.settings[card_title_key]
          assign card_button_text = block.settings[card_button_text_key]
          assign card_button_link = block.settings[card_button_link_key]
        %}

        {% if card_enabled %}
          <div class="ai-consultation-specialties__card-{{ ai_gen_id }}">
            <div class="ai-consultation-specialties__card-image-wrapper-{{ ai_gen_id }}">
              {% if card_image %}
                <img
                  src="{{ card_image | image_url: width: 400 }}"
                  alt="{{ card_title | escape }}"
                  class="ai-consultation-specialties__card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="400"
                  height="400"
                >
              {% else %}
                <div class="ai-consultation-specialties__card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'image' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            {% if card_title != blank %}
              <h3 class="ai-consultation-specialties__card-title-{{ ai_gen_id }}">
                {{ card_title }}
              </h3>
            {% endif %}

            {% if card_button_text != blank %}
              <a
                href="{{ card_button_link }}"
                class="ai-consultation-specialties__card-button-{{ ai_gen_id }}"
              >
                {{ card_button_text }}
              </a>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</consultation-specialties-{{ ai_gen_id }}>

<script>
  (function() {
    class ConsultationSpecialties{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccessibility();
      }

      setupAccessibility() {
        const cards = this.querySelectorAll('.ai-consultation-specialties__card-{{ ai_gen_id }}');
        cards.forEach((card) => {
          card.setAttribute('role', 'article');
        });
      }
    }

    customElements.define('consultation-specialties-{{ ai_gen_id }}', ConsultationSpecialties{{ ai_gen_id }});
  })();
</script>

