<div
  id="petaloons-size-widget"
  class="petaloons-size-widget"
  data-size-chart-url="/pages/size-chart"
  data-whatsapp-url="https://wa.me/0000000000?text=Hi%20Petaloons%2C%20I%20need%20help%20with%20dog%20clothing%20size."
>
  <button
    type="button"
    class="petaloons-size-widget__launcher"
    data-widget-open
    aria-controls="petaloons-size-widget-panel"
    aria-expanded="false"
  >
    <span class="petaloons-size-widget__launcher-icon" aria-hidden="true">🐶</span>
    <span class="petaloons-size-widget__launcher-label">Find My Pet&rsquo;s Size</span>
  </button>

  <aside
    id="petaloons-size-widget-panel"
    class="petaloons-size-widget__panel"
    data-widget-panel
    aria-hidden="true"
    aria-label="Petaloons Size Assistant"
    role="dialog"
  >
    <div class="petaloons-size-widget__panel-inner">
      <header class="petaloons-size-widget__header">
        <div>
          <h2 class="petaloons-size-widget__title">Petaloons Size Assistant 🐶</h2>
          <p class="petaloons-size-widget__subtitle">Find the best fit for your pet</p>
        </div>
        <button
          type="button"
          class="petaloons-size-widget__icon-button"
          data-widget-close
          aria-label="Close size assistant"
        >
          <span aria-hidden="true">&times;</span>
        </button>
      </header>

      <div class="petaloons-size-widget__body" data-chat-log aria-live="polite" aria-atomic="false"></div>

      <footer class="petaloons-size-widget__footer">
        <div class="petaloons-size-widget__input-area" data-input-area></div>
        <button type="button" class="petaloons-size-widget__restart" data-widget-restart>
          Restart chat
        </button>
      </footer>
    </div>
  </aside>
</div>
