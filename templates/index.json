    "custom_liquid_PKJ3Nx": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<section class=\"pet-vet-banner\">\n  <div class=\"pet-vet-wrap\">\n    \n    <div class=\"pet-vet-content\">\n      <span class=\"pet-vet-badge\">🐾 Petaloons Vet Care</span>\n\n      <h2>Book Trusted Vet Appointments Online</h2>\n\n      <p>\n        Connect with experienced veterinarians for your pet’s health, vaccination,\n        skin issues, dental care, digestion, and regular checkups — all in one place.\n      </p>\n\n      <div class=\"pet-vet-points\">\n        <div>✅ Choose Doctor</div>\n        <div>✅ Select Time Slot</div>\n        <div>✅ Instant Booking</div>\n      </div>\n\n      <div class=\"pet-vet-actions\">\n        <a href=\"/pages/book-vet-appointment\" class=\"pet-vet-btn primary\">\n          Book Appointment\n        </a>\n \n      </div>\n    </div>\n\n    <div class=\"pet-vet-image\">\n      <img \n        src=\"https://cdn.shopify.com/s/files/1/0611/1107/4890/files/ChatGPTImageApr22_2026_04_33_10PM.png?v=1776855825\"\n        alt=\"Book online veterinary appointment for dogs and pets with Petaloons\"\n        loading=\"lazy\"\n      >\n    </div>\n\n  </div>\n</section>\n\n<style>\n.pet-vet-banner {\n  width: 100%;\n  padding: 70px 20px;\n  background: linear-gradient(135deg, #fff7ec 0%, #ffffff 55%, #eef8ff 100%);\n  font-family: inherit;\n}\n\n.pet-vet-wrap {\n  max-width: 1200px;\n  margin: auto;\n  display: grid;\n  grid-template-columns: 1.1fr 0.9fr;\n  gap: 45px;\n  align-items: center;\n  background: #ffffff;\n  border-radius: 32px;\n  padding: 45px;\n  box-shadow: 0 20px 60px rgba(0,0,0,0.08);\n  overflow: hidden;\n}\n\n.pet-vet-badge {\n  display: inline-block;\n  background: #ffe3bd;\n  color: #7a3d00;\n  padding: 10px 18px;\n  border-radius: 40px;\n  font-size: 14px;\n  font-weight: 700;\n  margin-bottom: 18px;\n}\n\n.pet-vet-content h2 {\n  font-size: clamp(34px, 5vw, 58px);\n  line-height: 1.05;\n  margin: 0 0 18px;\n  color: #1f2933;\n  font-weight: 800;\n}\n\n.pet-vet-content p {\n  font-size: 18px;\n  line-height: 1.7;\n  color: #5f6c7b;\n  max-width: 620px;\n  margin-bottom: 24px;\n}\n\n.pet-vet-points {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  margin-bottom: 30px;\n}\n\n.pet-vet-points div {\n  background: #f4f9ff;\n  color: #1f4b6e;\n  padding: 12px 16px;\n  border-radius: 14px;\n  font-size: 15px;\n  font-weight: 700;\n}\n\n.pet-vet-actions {\n  display: flex;\n  gap: 14px;\n  flex-wrap: wrap;\n}\n\n.pet-vet-btn {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  padding: 15px 26px;\n  border-radius: 16px;\n  text-decoration: none;\n  font-size: 16px;\n  font-weight: 800;\n  transition: all 0.25s ease;\n}\n\n.pet-vet-btn.primary {\n  background: #f7941d;\n  color: #ffffff;\n  box-shadow: 0 10px 25px rgba(247,148,29,0.35);\n}\n\n.pet-vet-btn.primary:hover {\n  transform: translateY(-3px);\n  background: #e98208;\n}\n\n.pet-vet-btn.secondary {\n  background: #ffffff;\n  color: #1f2933;\n  border: 2px solid #e5e7eb;\n}\n\n.pet-vet-btn.secondary:hover {\n  transform: translateY(-3px);\n  border-color: #f7941d;\n  color: #f7941d;\n}\n\n.pet-vet-image {\n  position: relative;\n}\n\n.pet-vet-image img {\n  width: 100%;\n  height: 430px;\n  object-fit: cover;\n  border-radius: 28px;\n  display: block;\n  box-shadow: 0 16px 40px rgba(0,0,0,0.12);\n}\n\n@media (max-width: 900px) {\n  .pet-vet-wrap {\n    grid-template-columns: 1fr;\n    padding: 30px;\n  }\n\n  .pet-vet-image img {\n    height: 320px;\n  }\n}\n\n@media (max-width: 520px) {\n  .pet-vet-banner {\n    padding: 35px 14px;\n  }\n\n  .pet-vet-wrap {\n    padding: 24px;\n    border-radius: 24px;\n  }\n\n  .pet-vet-actions {\n    flex-direction: column;\n  }\n\n  .pet-vet-btn {\n    width: 100%;\n  }\n\n  .pet-vet-image img {\n    height: 260px;\n  }\n}\n</style>",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
    "custom_liquid_jLD8gX": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<section class=\"pet-reviews-section\">\n  <div class=\"pet-reviews-container\">\n\n    <div class=\"pet-reviews-header\">\n      <span class=\"pet-reviews-badge\">⭐ Customer Love</span>\n      <h2>Happy Pets, Happier Parents</h2>\n      <p>\n        Real reviews from Indian pet parents who trust Petaloons for stylish,\n        comfortable, and perfect-fit dog outfits.\n      </p>\n    </div>\n\n    <div class=\"pet-reviews-slider\">\n      <div class=\"pet-reviews-track\">\n\n        <div class=\"pet-review-card\">\n          <div class=\"pet-stars\">★★★★★</div>\n          <p>“Perfect fit and amazing quality! My dog looked so cute in the sherwani.”</p>\n          <h4>Priya Sharma</h4>\n          <span>Mumbai</span>\n        </div>\n\n        <div class=\"pet-review-card\">\n          <div class=\"pet-stars\">★★★★★</div>\n          <p>“Fabric is soft and comfortable. My pug wore it for the full function without any issue.”</p>\n          <h4>Rahul Verma</h4>\n          <span>Nagpur</span>\n        </div>\n\n        <div class=\"pet-review-card\">\n          <div class=\"pet-stars\">★★★★★</div>\n          <p>“The dog lehenga was beautiful. Stitching and finishing were much better than expected.”</p>\n          <h4>Anjali Mehta</h4>\n          <span>Pune</span>\n        </div>\n\n        <div class=\"pet-review-card\">\n          <div class=\"pet-stars\">★★★★★</div>\n          <p>“Size was accurate and delivery was quick. Petaloons is now my go-to brand.”</p>\n          <h4>Amit Deshmukh</h4>\n          <span>Nagpur</span>\n        </div>\n\n        <div class=\"pet-review-card\">\n          <div class=\"pet-stars\">★★★★★</div>\n          <p>“Loved the tuxedo! It made our pet look like a star at the birthday party.”</p>\n          <h4>Neha Kapoor</h4>\n          <span>Delhi</span>\n        </div>\n\n        <div class=\"pet-review-card\">\n          <div class=\"pet-stars\">★★★★★</div>\n          <p>“Very good quality and comfortable fitting. Worth buying for festive occasions.”</p>\n          <h4>Siddharth Iyer</h4>\n          <span>Bengaluru</span>\n        </div>\n\n        <!-- Duplicate cards for smooth infinite scroll -->\n\n        <div class=\"pet-review-card\">\n          <div class=\"pet-stars\">★★★★★</div>\n          <p>“Perfect fit and amazing quality! My dog looked so cute in the sherwani.”</p>\n          <h4>Priya Sharma</h4>\n          <span>Mumbai</span>\n        </div>\n\n        <div class=\"pet-review-card\">\n          <div class=\"pet-stars\">★★★★★</div>\n          <p>“Fabric is soft and comfortable. My pug wore it for the full function without any issue.”</p>\n          <h4>Rahul Verma</h4>\n          <span>Nagpur</span>\n        </div>\n\n        <div class=\"pet-review-card\">\n          <div class=\"pet-stars\">★★★★★</div>\n          <p>“The dog lehenga was beautiful. Stitching and finishing were much better than expected.”</p>\n          <h4>Anjali Mehta</h4>\n          <span>Pune</span>\n        </div>\n\n      </div>\n    </div>\n\n  </div>\n</section>\n\n<style>\n.pet-reviews-section {\n  width: 100%;\n  padding: 70px 20px;\n  background: linear-gradient(135deg, #fff8ef 0%, #ffffff 55%, #f2fbff 100%);\n  font-family: inherit;\n  overflow: hidden;\n}\n\n.pet-reviews-container {\n  max-width: 1200px;\n  margin: auto;\n}\n\n.pet-reviews-header {\n  text-align: center;\n  max-width: 760px;\n  margin: 0 auto 42px;\n}\n\n.pet-reviews-badge {\n  display: inline-block;\n  background: #ffe3bd;\n  color: #7a3d00;\n  padding: 10px 18px;\n  border-radius: 40px;\n  font-size: 14px;\n  font-weight: 800;\n  margin-bottom: 16px;\n}\n\n.pet-reviews-header h2 {\n  font-size: clamp(32px, 4vw, 50px);\n  line-height: 1.1;\n  color: #1f2933;\n  margin: 0 0 14px;\n  font-weight: 900;\n}\n\n.pet-reviews-header p {\n  color: #5f6c7b;\n  font-size: 17px;\n  line-height: 1.7;\n  margin: 0;\n}\n\n.pet-reviews-slider {\n  position: relative;\n  overflow: hidden;\n  padding: 10px 0;\n}\n\n.pet-reviews-slider::before,\n.pet-reviews-slider::after {\n  content: \"\";\n  position: absolute;\n  top: 0;\n  width: 90px;\n  height: 100%;\n  z-index: 2;\n  pointer-events: none;\n}\n\n.pet-reviews-slider::before {\n  left: 0;\n  background: linear-gradient(to right, #fff8ef, transparent);\n}\n\n.pet-reviews-slider::after {\n  right: 0;\n  background: linear-gradient(to left, #f2fbff, transparent);\n}\n\n.pet-reviews-track {\n  display: flex;\n  gap: 22px;\n  width: max-content;\n  animation: petReviewScroll 32s linear infinite;\n}\n\n.pet-reviews-slider:hover .pet-reviews-track {\n  animation-play-state: paused;\n}\n\n.pet-review-card {\n  width: 330px;\n  min-height: 250px;\n  background: #ffffff;\n  border-radius: 26px;\n  padding: 26px;\n  box-shadow: 0 16px 45px rgba(0,0,0,0.08);\n  border: 1px solid #f1f1f1;\n  display: flex;\n  flex-direction: column;\n  justify-content: space-between;\n}\n\n.pet-stars {\n  color: #f7941d;\n  font-size: 20px;\n  letter-spacing: 2px;\n  margin-bottom: 14px;\n}\n\n.pet-review-card p {\n  color: #374151;\n  font-size: 16px;\n  line-height: 1.65;\n  margin: 0 0 22px;\n}\n\n.pet-review-card h4 {\n  color: #1f2933;\n  font-size: 17px;\n  margin: 0 0 4px;\n  font-weight: 900;\n}\n\n.pet-review-card span {\n  color: #7b8794;\n  font-size: 14px;\n  font-weight: 600;\n}\n\n@keyframes petReviewScroll {\n  0% {\n    transform: translateX(0);\n  }\n  100% {\n    transform: translateX(-55%);\n  }\n}\n\n@media (max-width: 768px) {\n  .pet-reviews-section {\n    padding: 48px 14px;\n  }\n\n  .pet-review-card {\n    width: 280px;\n    min-height: 250px;\n    padding: 22px;\n  }\n\n  .pet-reviews-slider::before,\n  .pet-reviews-slider::after {\n    width: 35px;\n  }\n\n  .pet-reviews-track {\n    animation-duration: 26s;\n  }\n}\n\n@media (prefers-reduced-motion: reduce) {\n  .pet-reviews-track {\n    animation: none;\n    overflow-x: auto;\n  }\n}\n</style>",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
