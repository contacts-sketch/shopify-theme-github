tw-couple-link\">\n        <a href=\"/collections/dog-couple-dress\" aria-label=\"Shop matching couple outfits – sherwani and lehenga set\">\n          👫 Also available as Matching Couple Sets →\n        </a>\n      </div>\n\n    </div>\n\n    <!-- RIGHT: Image Showcase -->\n    <div class=\"ptw-visual\" aria-label=\"Dog wedding outfit showcase\">\n\n      <!-- Floating festive badge -->\n      <div class=\"ptw-float-badge\" aria-hidden=\"true\">\n        <span>✨ New</span>\n        Wedding\n        Collection\n        2025\n      </div>\n\n      <!-- Sherwani card -->\n      <article class=\"ptw-card ptw-card-sherwani\" itemscope itemtype=\"https://schema.org/Product\">\n        <div class=\"ptw-card-img-wrap\">\n          <img\n            src=\"https://cdn.shopify.com/s/files/1/0611/1107/4890/files/2_c5c38f2e-9dfb-45c5-a0a8-a196137406ec.png?v=1774978817\"\n            alt=\"Dog wearing premium golden sherwani for wedding – ethnic festive wear by Petaloons\"\n            loading=\"eager\"\n            fetchpriority=\"high\"\n            width=\"480\"\n            height=\"600\"\n            itemprop=\"image\"\n          >\n        </div>\n        <div class=\"ptw-card-overlay ptw-overlay-sherwani\">\n          <div class=\"ptw-card-info\">\n            <p class=\"ptw-card-cat\" itemprop=\"category\">Groom Collection</p>\n            <h3 itemprop=\"name\">Dog Sherwani</h3>\n            <p class=\"ptw-card-tag\">Wedding · Diwali · Eid</p>\n          </div>\n          <a href=\"/collections/dog-sherwani-collection-india\" class=\"ptw-card-cta\" itemprop=\"url\" aria-label=\"Explore dog sherwani collection\">Explore →</a>\n        </div>\n      </article>\n\n      <!-- Lehenga card -->\n      <article class=\"ptw-card ptw-card-lehenga\" itemscope itemtype=\"https://schema.org/Product\">\n        <div class=\"ptw-card-img-wrap\">\n          <img\n            src=\"https://cdn.shopify.com/s/files/1/0611/1107/4890/files/1.0.png?v=1777115848\"\n            alt=\"Dog wearing beautiful pink lehenga for wedding and festive occasion by Petaloons\"\n            loading=\"eager\"\n            fetchpriority=\"high\"\n            width=\"480\"\n            height=\"600\"\n            itemprop=\"image\"\n          >\n        </div>\n        <div class=\"ptw-card-overlay ptw-overlay-lehenga\">\n          <div class=\"ptw-card-info\">\n            <p class=\"ptw-card-cat\" itemprop=\"category\">Bride Collection</p>\n            <h3 itemprop=\"name\">Dog Lehenga</h3>\n            <p class=\"ptw-card-tag\">Wedding · Navratri · Teej</p>\n          </div>\n          <a href=\"/collections/dog-lehengas\" class=\"ptw-card-cta\" itemprop=\"url\" aria-label=\"Explore dog lehenga collection\">Explore →</a>\n        </div>\n      </article>\n\n      <!-- Floating star rating -->\n      <div class=\"ptw-rating-pill\" aria-label=\"Average customer rating\">\n        <span class=\"ptw-stars\">★★★★★</span>\n        <span>4.9 · 500+ Reviews</span>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<style>\n/* ============================\n   PETALOONS WEDDING HERO BANNER\n   ============================ */\n\n.ptw-hero {\n  position: relative;\n  width: 100%;\n  overflow: hidden;\n  padding: 72px 20px 80px;\n  background:\n    radial-gradient(ellipse at 0% 0%, rgba(180,100,20,0.12) 0%, transparent 40%),\n    radial-gradient(ellipse at 100% 100%, rgba(180,20,60,0.10) 0%, transparent 40%),\n    radial-gradient(ellipse at 50% 50%, rgba(255,215,80,0.06) 0%, transparent 70%),\n    linear-gradient(150deg, #fffaf0 0%, #fff8f0 35%, #fff0f5 65%, #fff5e6 100%);\n  font-family: inherit;\n}\n\n/* Decorative background circles */\n.ptw-decor {\n  position: absolute;\n  border-radius: 50%;\n  pointer-events: none;\n  z-index: 0;\n}\n.ptw-decor-tl {\n  width: 560px;\n  height: 560px;\n  top: -160px;\n  left: -160px;\n  background: radial-gradient(circle, rgba(255,200,80,0.14) 0%, transparent 70%);\n  border: 1px dashed rgba(180,120,20,0.15);\n}\n.ptw-decor-br {\n  width: 480px;\n  height: 480px;\n  bottom: -140px;\n  right: -100px;\n  background: radial-gradient(circle, rgba(200,30,80,0.10) 0%, transparent 70%);\n  border: 1px dashed rgba(180,30,60,0.12);\n}\n\n.ptw-inner {\n  position: relative;\n  z-index: 1;\n  max-width: 1300px;\n  margin: 0 auto;\n  display: grid;\n  grid-template-columns: 1fr 1.1fr;\n  gap: 60px;\n  align-items: center;\n}\n\n/* ---- Occasion tags ---- */\n.ptw-occasion-tags {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px;\n  margin-bottom: 24px;\n}\n.ptw-tag {\n  background: rgba(255,255,255,0.9);\n  border: 1px solid rgba(180,100,20,0.22);\n  color: #7a3d00;\n  padding: 7px 14px;\n  border-radius: 999px;\n  font-size: 13px;\n  font-weight: 700;\n  box-shadow: 0 3px 10px rgba(0,0,0,0.06);\n  backdrop-filter: blur(6px);\n}\n\n/* ---- Heading ---- */\n.ptw-content h1 {\n  margin: 0 0 20px;\n  font-size: clamp(36px, 4.5vw, 68px);\n  line-height: 1.05;\n  letter-spacing: -1.5px;\n  font-weight: 950;\n  color: #2a1500;\n}\n.ptw-accent {\n  background: linear-gradient(135deg, #c8173a, #e05a10);\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n/* ---- Description ---- */\n.ptw-content p {\n  margin: 0 0 28px;\n  font-size: 17px;\n  line-height: 1.75;\n  color: #5a3a1a;\n  max-width: 560px;\n}\n.ptw-content p strong {\n  color: #2a1500;\n  font-weight: 800;\n}\n\n/* ---- Trust row ---- */\n.ptw-trust {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 10px 20px;\n  margin-bottom: 32px;\n}\n.ptw-trust-item {\n  display: flex;\n  align-items: center;\n  gap: 7px;\n  font-size: 14px;\n  font-weight: 700;\n  color: #4a2800;\n}\n.ptw-trust-icon {\n  font-size: 18px;\n}\n\n/* ---- CTA buttons ---- */\n.ptw-ctas {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 14px;\n  margin-bottom: 20px;\n}\n.ptw-btn {\n  display: inline-flex;\n  align-items: center;\n  gap: 9px;\n  min-height: 56px;\n  padding: 0 28px;\n  border-radius: 18px;\n  font-size: 16px;\n  font-weight: 900;\n  text-decoration: none;\n  transition: all 0.22s ease;\n  white-space: nowrap;\n}\n.ptw-btn-primary {\n  background: linear-gradient(135deg, #b8360a, #e05a10);\n  color: #fff;\n  box-shadow: 0 14px 36px rgba(180,54,10,0.30);\n}\n.ptw-btn-primary:hover {\n  transform: translateY(-3px);\n  box-shadow: 0 20px 44px rgba(180,54,10,0.38);\n}\n.ptw-btn-secondary {\n  background: linear-gradient(135deg, #7a0028, #c8173a);\n  color: #fff;\n  box-shadow: 0 14px 36px rgba(130,0,50,0.28);\n}\n.ptw-btn-secondary:hover {\n  transform: translateY(-3px);\n  box-shadow: 0 20px 44px rgba(130,0,50,0.36);\n}\n\n/* ---- Couple link ---- */\n.ptw-couple-link a {\n  font-size: 14px;\n  font-weight: 800;\n  color: #7a3d00;\n  text-decoration: none;\n  border-bottom: 1px dashed rgba(122,61,0,0.4);\n  padding-bottom: 2px;\n  transition: color 0.2s;\n}\n.ptw-couple-link a:hover {\n  color: #c8173a;\n  border-color: #c8173a;\n}\n\n/* ============================\n   VISUAL / IMAGE CARDS\n   ============================ */\n\n.ptw-visual {\n  position: relative;\n  min-height: 620px;\n}\n\n/* Background blob */\n.ptw-visual::before {\n  content: \"\";\n  position: absolute;\n  inset: 40px;\n  background: linear-gradient(135deg, rgba(255,210,100,0.25), rgba(210,30,70,0.12));\n  border-radius: 50% 45% 55% 40%;\n  z-index: 0;\n  filter: blur(12px);\n}\n\n.ptw-card {\n  position: absolute;\n  overflow: hidden;\n  border-radius: 32px;\n  background: #fff;\n  box-shadow: 0 28px 72px rgba(0,0,0,0.16);\n  border: 6px solid rgba(255,255,255,0.95);\n  z-index: 2;\n  transition: transform 0.3s ease;\n}\n.ptw-card:hover {\n  transform: scale(1.02);\n}\n\n.ptw-card-sherwani {\n  width: 54%;\n  height: 520px;\n  left: 0;\n  top: 20px;\n  z-index: 3;\n}\n.ptw-card-lehenga {\n  width: 54%;\n  height: 520px;\n  right: 0;\n  bottom: 0;\n  z-index: 2;\n}\n\n.ptw-card-img-wrap {\n  width: 100%;\n  height: 100%;\n}\n.ptw-card-img-wrap img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n}\n\n/* Card overlay with product info */\n.ptw-card-overlay {\n  position: absolute;\n  inset: 0;\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-end;\n  padding: 0 20px 20px;\n  background: linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.18) 45%, transparent 100%);\n}\n.ptw-overlay-sherwani {\n  background: linear-gradient(to top, rgba(130,40,0,0.75) 0%, rgba(80,20,0,0.20) 45%, transparent 100%);\n}\n.ptw-overlay-lehenga {\n  background: linear-gradient(to top, rgba(100,0,40,0.75) 0%, rgba(60,0,30,0.20) 45%, transparent 100%);\n}\n\n.ptw-card-info {\n  margin-bottom: 14px;\n}\n.ptw-card-cat {\n  font-size: 11px;\n  font-weight: 800;\n  letter-spacing: 1.5px;\n  text-transform: uppercase;\n  color: rgba(255,220,130,0.95);\n  margin: 0 0 5px;\n}\n.ptw-card-overlay h3 {\n  font-size: 22px;\n  font-weight: 950;\n  color: #ffffff;\n  margin: 0 0 5px;\n  line-height: 1.1;\n}\n.ptw-card-tag {\n  font-size: 12px;\n  color: rgba(255,255,255,0.8);\n  font-weight: 600;\n  margin: 0;\n}\n\n.ptw-card-cta {\n  display: inline-flex;\n  align-items: center;\n  background: rgba(255,255,255,0.18);\n  border: 1.5px solid rgba(255,255,255,0.45);\n  color: #fff;\n  text-decoration: none;\n  font-size: 13px;\n  font-weight: 800;\n  padding: 8px 16px;\n  border-radius: 12px;\n  backdrop-filter: blur(8px);\n  width: fit-content;\n  transition: background 0.2s;\n}\n.ptw-card-cta:hover {\n  background: rgba(255,255,255,0.30);\n}\n\n/* Floating new badge */\n.ptw-float-badge {\n  position: absolute;\n  top: -6px;\n  right: 46%;\n  z-index: 10;\n  background: linear-gradient(135deg, #ffd700, #ff8c00);\n  color: #3a1a00;\n  border-radius: 16px;\n  padding: 10px 14px;\n  font-size: 12px;\n  font-weight: 900;\n  line-height: 1.3;\n  text-align: center;\n  box-shadow: 0 8px 22px rgba(200,120,0,0.35);\n  border: 2px solid rgba(255,255,255,0.6);\n}\n.ptw-float-badge span {\n  display: block;\n  font-size: 10px;\n  background: rgba(0,0,0,0.15);\n  border-radius: 8px;\n  padding: 2px 6px;\n  margin-bottom: 4px;\n  font-weight: 800;\n  letter-spacing: 1px;\n}\n\n/* Rating pill */\n.ptw-rating-pill {\n  position: absolute;\n  bottom: 28px;\n  left: 50%;\n  transform: translateX(-50%);\n  z-index: 10;\n  background: #fff;\n  border-radius: 999px;\n  padding: 10px 18px;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  font-size: 13px;\n  font-weight: 800;\n  color: #2a1500;\n  box-shadow: 0 10px 30px rgba(0,0,0,0.14);\n  white-space: nowrap;\n  border: 1px solid rgba(180,100,20,0.15);\n}\n.ptw-stars {\n  color: #f7941d;\n  font-size: 15px;\n  letter-spacing: 1px;\n}\n\n/* ============================\n   RESPONSIVE\n   ============================ */\n\n@media (max-width: 1024px) {\n  .ptw-inner {\n    grid-template-columns: 1fr;\n    gap: 48px;\n    text-align: center;\n  }\n  .ptw-occasion-tags,\n  .ptw-trust,\n  .ptw-ctas {\n    justify-content: center;\n  }\n  .ptw-content p {\n    margin-left: auto;\n    margin-right: auto;\n  }\n  .ptw-visual {\n    min-height: 560px;\n  }\n}\n\n@media (max-width: 600px) {\n  .ptw-hero {\n    padding: 48px 14px 56px;\n  }\n  .ptw-content h1 {\n    letter-spacing: -0.8px;\n  }\n  .ptw-ctas {\n    flex-direction: column;\n  }\n  .ptw-btn {\n    width: 100%;\n    justify-content: center;\n  }\n  .ptw-visual {\n    min-height: 500px;\n  }\n  .ptw-card-sherwani,\n  .ptw-card-lehenga {\n    height: 400px;\n  }\n  .ptw-float-badge {\n    right: 42%;\n  }\n}\n\n@media (max-width: 420px) {\n  .ptw-visual {\n    min-height: 420px;\n  }\n  .ptw-card-sherwani,\n  .ptw-card-lehenga {\n    height: 330px;\n  }\n  .ptw-rating-pill {\n    bottom: 14px;\n    font-size: 12px;\n    padding: 8px 14px;\n  }\n}\n</style>",
